PORT=3000
NODE_ENV=development

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=snapvault_dev
DB_USER=root
DB_PASS=

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars

# Email (Gmail SMTP - use App Password, not your Gmail login password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=SnapVault <your_gmail@gmail.com>
